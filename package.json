{
  "name": "web3bio-profile-api",
  "version": "0.4.6",
  "packageManager": "pnpm@10.32.1",
  "description": "Web3 Identity Resolver · Web3 Identity Kit · Web3 Domain Name Service Resolver",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "test:diff": "RUN_DIFF_TESTS=1 jest __tests__/diff.test.js",
    "lint": "eslint .",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview --remote --port 3000",
    "staging": "opennextjs-cloudflare build && wrangler versions upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "graphql": "^16.11.0",
    "highlight.js": "11.11.1",
    "jose": "^5.10.0",
    "next": "15.5.19",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "^2.52.2",
    "web3bio-profile-kit": "^0.2.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/jest": "^29.5.14",
    "@types/node": "20.12.8",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.4.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.19",
    "jest": "^29.7.0",
    "sass": "^1.101.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "wrangler": "^4.101.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": ">=7.29.6",
      "@isaacs/brace-expansion": ">=5.0.1",
      "body-parser": ">=2.2.1",
      "diff": ">=4.0.4",
      "esbuild": ">=0.28.1",
      "fast-xml-parser": ">=5.3.8",
      "flatted": ">=3.4.2",
      "form-data": ">=4.0.6",
      "minimatch": ">=10.2.3",
      "path-to-regexp": ">=8.4.0",
      "picomatch": ">=4.0.4",
      "ajv": ">=6.14.0",
      "js-yaml": ">=4.2.0",
      "postcss": ">=8.5.10",
      "qs": ">=6.14.2",
      "ws": ">=8.21.0",
      "yaml": ">=2.8.3"
    }
  }
}
